    <bpmn:sequenceFlow id="Flow_07u03v5" sourceRef="Gateway_0bwa1rw" targetRef="Activity_0pdfviy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${employeeDecision == 'ACCEPTED' || employeeDecision == 'REJECTED'}</bpmn:conditionExpression>
